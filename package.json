{
  "name": "utility-spareparts",
  "version": "1.0.0",
  "description": "SAP CAP service layer for utilities spare-parts fulfilment",
  "private": true,
  "scripts": {
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "start": "cds-serve",
    "watch": "cds watch",
    "watch-field-maintenance-ui": "cds watch --open utility.spareparts.fieldmaintenanceui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.13.0",
    "rimraf": "^5.0.5"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/field-maintenance-ui"
  ]
}
